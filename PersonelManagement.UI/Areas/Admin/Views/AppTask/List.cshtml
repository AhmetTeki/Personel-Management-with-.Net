@using PersonelManagement.Application.Dtos
@model PagedResult<PersonelManagement.Application.Dtos.AppTaskListDto>
@{
    Layout = "_Layout";
    int count = 1;
}
<div class="d-flex justify-content-between  align-items-center pt-3 pb-2 mb-3 border-bottom">
    <a asp-action="Create" asp-controller="AppTask" asp-area="Admin" class="btn btn-primary mb-4"> Yeni Aciliyet Durumu Ekle</a>
    <form class="input-group mb-2 shadow-sm" style="max-width: 320px;" asp-action="List" asp-controller="AppTask" asp-area="Admin" >
        <input type="text" name="s"
               class="form-control border-end-0"
               placeholder="İş Emri Ara">

        <button class="btn btn-primary px-3" type="submit">
            Ara
        </button>
    </form>
</div>

<table class="table">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Tanım</th>
            <th scope="col">Açıklama</th>
            <th scope="col">Öncelik</th>
            <th scope="col">Kullanıcı</th>
            <th scope="col">Durum</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Data.Count > 0)
        {
            @foreach (AppTaskListDto item in Model.Data)
            {
                <tr>
                    <th scope="row">@count</th>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.PriorityDefination</td>
                    <td>@item.User</td>
                    <td>@(item.State ? "Tamamlandı" : "Devam Ediyor")</td>
                    <td>
                        <a asp-action="Update" asp-controller="AppTask" asp-area="Admin" asp-route-id="@item.Id" class="btn btn-success">Detay</a>
                        <a asp-action="Delete" onclick="return confirm(`Silmek İstediğinizden Emin Misin?`)" asp-controller="AppTask"
                           asp-area="Admin" asp-route-id="@item.Id" class="btn btn-danger">Sil</a>
                    </td>
                </tr>
                count++;
            }
        }
        @if (Model.Data.Count <= 0)
        {
            <h3>Herhangi Bir Görev Bulunamadı</h3>
        }

    </tbody>
</table>

<nav aria-label="Page navigation example">
    <ul class="pagination">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item"><a class="page-link"  asp-route-activePage="@i" asp-action="List" asp-controller="AppTask"
                                     asp-area="Admin">@i</a></li>
        }

    </ul>
</nav>